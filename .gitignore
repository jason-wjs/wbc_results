# This repository is an experiment registry, not artifact storage.

# Large binary artifacts
*.avi
*.ckpt
*.log
*.mov
*.mp4
*.npy
*.npz
*.pth
*.pt
*.tar
*.tar.gz
*.tar.zst
*.zip

# Explicitly version the small shared testbed motion set.
!assets/
!assets/motion_data/
!assets/motion_data/*/
!assets/motion_data/*/motion.npz

# Common raw-output directories
checkpoints/
logs/
outputs/
rollouts/
videos/

# Captured command outputs
stderr.txt
stdout.txt

# Local/editor files
.DS_Store
.idea/
.ruff_cache/
.venv/
__pycache__/
